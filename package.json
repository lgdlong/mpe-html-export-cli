{
  "name": "mpe-html-export-cli",
  "version": "0.1.0",
  "description": "Standalone Markdown to HTML export CLI inspired by Markdown Preview Enhanced",
  "license": "NCSA",
  "repository": "https://github.com/shd101wyy/vscode-markdown-preview-enhanced",
  "keywords": [
    "markdown",
    "html",
    "export",
    "cli"
  ],
  "bin": {
    "mpe-html": "dist/src/cli.js"
  },
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "npm run build && node --test dist/test/cli.test.js",
    "start": "node dist/src/cli.js",
    "help": "node dist/src/cli.js --help"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.22",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-table-of-contents": "^0.8.0",
    "markdown-it-texmath": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
